#!/usr/bin/env python3
"""Wake a *parked* Claude Code session when a notify-worthy message arrives.

The MCP server can detect a new message (its background poll fires notify_command)
but cannot inject a turn into the model's loop — only the harness can. Two harness
mechanisms do that, and this script serves both:

  --follow (RECOMMENDED — run under the Monitor tool):
    dispatch-wait --follow        # stream one wake event per message, forever
    Monitor streams each printed line into the parked session as a wake event, so
    ONE persistent registration covers the whole session — nothing to re-arm after
    each message. This is what hooks/dispatch-arm.py nudges the model to start.

  one-shot (run as a Bash run_in_background task):
    dispatch-wait                 # block until a direct/must_read message, then exit
    The harness re-invokes the model on the task's *exit*; you must relaunch it to
    re-arm for the next message. Kept for standalone/scripted use.

    dispatch-wait --interval 1    # poll faster (default 2.0s)
    dispatch-wait --notify-on all # override the configured policy for this run
    dispatch-wait --max-lifetime 600

Why this beats `/loop`: /loop fires a whole model turn every interval whether
or not anything arrived. This spends *zero* model tokens while blocking and
wakes only on an actual qualifying arrival.

Policy (which messages qualify) is the shared notify_on setting — the SAME one
the server's desktop-notification poll uses (see notify_policy.should_notify).
With notify_on = "direct" an idle session wakes on messages addressed to it
(plus any must_read), and ignores channel/broadcast chatter.

Level-triggered: if a qualifying message is already unread at launch it exits
immediately, so re-arming after handling one leaves no window to miss the next.

Lifetime: by default there is no time cap. Instead the waiter exits the moment
its agent's presence flock drops — the MCP server releases it when the session
dies — so a backgrounded waiter can't outlive its session and orphan, whether or
not the harness reaps background tasks on close. Pass --max-lifetime to add a
wall-clock cap on top; standalone use (no live server to gate on) falls back to a
finite cap automatically.

Identity resolution (first that works):
  1. $MCP_DISPATCH_AGENT_ID — the recommended setup.
  2. The single live agent whose id starts with "<project>-" (launcher scheme).
     Skipped if zero or several match — too ambiguous.

Exit status is always 0 (clean wake, presence drop, or lifetime timeout); the
printed text says which. Read-only: never acks, marks, or deletes. Acknowledge
via the ack() tool.
"""

from __future__ import annotations

import argparse
import calendar
import fcntl
import hashlib
import json
import os
import re
import sys
import time
from pathlib import Path

# notify_policy.py lives at the repo root (parent of bin/).
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from notify_policy import should_notify  # noqa: E402

# When launched standalone (no live server holding the agent's presence), there's
# no session to gate our lifetime on, so cap it rather than poll forever.
STANDALONE_FALLBACK_SECONDS = 1800.0


def _configured(key: str) -> str | None:
    """Read a scalar key from the config file, if present (stdlib tomllib)."""
    cfg = os.environ.get("MCP_DISPATCH_CONFIG") or os.path.expanduser(
        "~/.config/mcp-dispatch/config.toml"
    )
    if not os.path.exists(cfg):
        return None
    try:
        import tomllib

        with open(cfg, "rb") as f:
            data = tomllib.load(f)
    except Exception:
        return None
    sub = data.get("dispatch")
    section = sub if isinstance(sub, dict) else {}
    val = data.get(key)
    if val is None:
        val = section.get(key)
    return str(val) if val is not None else None


def _dispatch_dir() -> Path:
    raw = (
        os.environ.get("MCP_DISPATCH_DIR")
        or os.environ.get("DISPATCH_DIR")
        or _configured("dispatch_dir")
        or "~/.config/mcp-dispatch/messages"
    )
    return Path(os.path.expanduser(raw))


def _state_dir() -> Path:
    """Per-user scratch dir for arm lockfiles. Overridable for tests."""
    raw = os.environ.get("MCP_DISPATCH_STATE_DIR") or "~/.cache/mcp-dispatch"
    return Path(os.path.expanduser(raw))


def _arm_lock_path(agent_id: str) -> Path:
    key = hashlib.md5(agent_id.encode(), usedforsecurity=False).hexdigest()[:8]
    return _state_dir() / f"wait-{key}.lock"


def _notify_on(cli_value: str | None) -> str:
    """Resolve the policy: CLI flag > env > config > "important" (server default)."""
    raw = (
        cli_value
        or os.environ.get("MCP_DISPATCH_NOTIFY_ON")
        or _configured("notify_on")
        or "important"
    )
    return raw.strip().lower()


def _presence_is_live(pf: Path) -> bool:
    """A live owner holds the exclusive flock on its presence file. If we can take
    the lock, nobody's home (uid-agnostic, pid-reuse-immune)."""
    try:
        fh = open(pf)
    except OSError:
        return False
    try:
        fcntl.flock(fh.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
        fcntl.flock(fh.fileno(), fcntl.LOCK_UN)
        return False
    except OSError:
        return True
    finally:
        fh.close()


def _resolve_agent_id(dispatch_dir: Path) -> str | None:
    explicit = (os.environ.get("MCP_DISPATCH_AGENT_ID") or "").strip().lower()
    if explicit:
        return explicit

    prefix = re.sub(r"^-*", "", re.sub(r"[^a-z0-9-]", "", os.path.basename(os.getcwd()).lower()))
    if not prefix:
        return None
    presence = dispatch_dir / ".presence"
    matches = []
    for pf in presence.glob("*.json"):
        try:
            data = json.loads(pf.read_text())
        except (json.JSONDecodeError, OSError):
            continue
        aid = data.get("agent_id", "")
        if aid.startswith(f"{prefix}-") and _presence_is_live(pf):
            matches.append(aid)
    return matches[0] if len(matches) == 1 else None


def _expired(msg: dict) -> bool:
    ttl = msg.get("ttl")
    if not ttl or ttl <= 0 or msg.get("must_read"):
        return False
    try:
        sent = calendar.timegm(time.strptime(msg.get("timestamp", ""), "%Y-%m-%dT%H:%M:%SZ"))
    except (ValueError, TypeError):
        return False
    return time.time() > sent + ttl


def _qualifying(dispatch_dir: Path, agent_id: str, notify_on: str) -> list[dict]:
    """Unread, unexpired messages in this agent's inbox that the policy notifies on."""
    inbox = dispatch_dir / agent_id
    out = []
    for f in sorted(inbox.glob("*.json")):
        try:
            msg = json.loads(f.read_text())
        except (json.JSONDecodeError, OSError):
            continue
        if msg.get("state", "pending") != "pending" or _expired(msg):
            continue
        if should_notify(msg, notify_on, agent_id):
            out.append(msg)
    return out


def _oneline(agent_id: str, m: dict) -> str:
    """One-line render of a single qualifying message, for --follow stream mode.

    Under the Monitor tool each printed line becomes one wake event, so this must
    be a single flushed line carrying enough to triage without a peek()."""
    flags = ""
    if m.get("must_read"):
        flags += " 🔒"
    if m.get("priority") == "urgent":
        flags += " ‼"
    elif m.get("priority") == "high":
        flags += " !"
    # Surface cross-host provenance: a git-materialized message is tagged _via.
    via = " «remote»" if m.get("_via") == "git" else ""
    preview = (m.get("content", "") or "")[:140].replace("\n", " ")
    return (
        f"[mcp-dispatch] {m.get('from', '?')} → {agent_id}{flags}{via}: {preview}  "
        f"(id {m.get('id', '?')}) — peek() to read, ack() when handled"
    )


def _follow(
    dispatch_dir: Path,
    agent_id: str,
    notify_on: str,
    interval: float,
    gated: bool,
    presence_pf: Path,
    deadline: float | None,
    max_lifetime: float,
) -> int:
    """Stream mode: never exit on a hit. Print one line per newly-seen qualifying
    message and keep running, so a single persistent Monitor registration wakes a
    parked session on every arrival with zero re-arming. Exits only when the
    session's presence drops (or an explicit lifetime cap fires).

    Level-triggered like the one-shot path: any backlog already queued at launch
    is emitted immediately. Dedup is by message id — an id is emitted once, then
    remembered until it leaves the inbox (ack/expiry), which (ids being unique)
    can't recur, so `emitted` tracks only live messages, never full history."""
    emitted: set[str] = set()
    while True:
        hits = _qualifying(dispatch_dir, agent_id, notify_on)
        current: set[str] = set()
        for m in hits:
            mid = str(m.get("id") or "")
            current.add(mid)
            if mid not in emitted:
                print(_oneline(agent_id, m), flush=True)
        emitted = current
        if gated and not _presence_is_live(presence_pf):
            print(
                f"[mcp-dispatch] session for {agent_id} ended (presence dropped) — watch exiting.",
                flush=True,
            )
            return 0
        if deadline is not None and time.monotonic() >= deadline:
            print(
                f"[mcp-dispatch] watch for {agent_id} hit its {int(max_lifetime)}s "
                f"cap (notify_on={notify_on}). Re-arm if still idle.",
                flush=True,
            )
            return 0
        time.sleep(interval)


def _summary(agent_id: str, notify_on: str, msgs: list[dict]) -> str:
    lines = [f"[mcp-dispatch] {len(msgs)} message(s) for {agent_id} (notify_on={notify_on}):"]
    for m in msgs[:10]:
        flags = ""
        if m.get("must_read"):
            flags += " 🔒"
        if m.get("priority") == "urgent":
            flags += " !"
        preview = (m.get("content", "") or "")[:100].replace("\n", " ")
        lines.append(
            f"  from {m.get('from', '?')} → {m.get('to', '?')}{flags}: "
            f"{preview}  (id {m.get('id', '?')})"
        )
    lines.append(
        "Use peek() to read in full and ack() when handled, "
        "then launch dispatch-wait again to re-arm."
    )
    return "\n".join(lines)


def main() -> int:
    ap = argparse.ArgumentParser(description="Block until a notify-worthy dispatch message lands.")
    ap.add_argument("--interval", type=float, default=2.0, help="poll seconds (default 2.0)")
    ap.add_argument(
        "--max-lifetime",
        type=float,
        default=0.0,
        help="seconds before a clean timeout exit. Default 0 = no time cap: the "
        "waiter instead exits the moment its agent's presence drops (the session "
        "ended), so it can't outlive its session and orphan. With no live presence "
        "at startup (standalone use), 0 falls back to a finite cap.",
    )
    ap.add_argument("--notify-on", default=None, help="override the configured policy for this run")
    ap.add_argument(
        "--follow",
        action="store_true",
        help="stream mode: don't exit on the first hit — print one line per "
        "qualifying message and keep running until presence drops. Designed to run "
        "under the Monitor tool so a single registration wakes a parked session on "
        "every message, with no re-arming.",
    )
    args = ap.parse_args()

    dispatch_dir = _dispatch_dir()
    if not dispatch_dir.is_dir():
        print(f"[mcp-dispatch] no relay at {dispatch_dir} — nothing to wait on.")
        return 0

    agent_id = _resolve_agent_id(dispatch_dir)
    if not agent_id:
        print(
            "[mcp-dispatch] could not resolve agent id (set $MCP_DISPATCH_AGENT_ID) — not waiting."
        )
        return 0

    # Single-instance lock: hold it for our lifetime so (a) two waiters never arm
    # the same agent and (b) hooks/dispatch-arm.py can detect liveness by probing
    # this same flock. Released automatically by the kernel when we exit. Degrade
    # to running unlocked if the scratch dir is unwritable.
    lock_fh = None
    try:
        lock_path = _arm_lock_path(agent_id)
        lock_path.parent.mkdir(parents=True, exist_ok=True)
        lock_fh = open(lock_path, "a+")  # noqa: SIM115 — held for process lifetime
    except OSError:
        lock_fh = None
    if lock_fh is not None:
        locked = False
        for attempt in range(2):
            try:
                fcntl.flock(lock_fh.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
                locked = True
                break
            except OSError:
                # The arm hook probes this same lock (acquire+release) to test
                # liveness; that momentary hold could collide with us starting up.
                # Retry once after a beat so a probe never masquerades as a rival
                # waiter — only a truly-held lock survives the retry.
                if attempt == 0:
                    time.sleep(0.05)
        if not locked:
            lock_fh.close()
            print(
                f"[mcp-dispatch] a waiter is already armed for {agent_id}; not starting a second."
            )
            return 0

    notify_on = _notify_on(args.notify_on)

    # Orphan guard. Default (no time cap) ties our lifetime to the session: we
    # exit the instant our agent's presence flock drops, which the MCP server
    # releases when it dies. That makes an orphaned waiter impossible regardless
    # of whether the harness reaps background tasks on session close. If no
    # presence exists at startup (standalone use, no live server), there's nothing
    # to gate on, so fall back to a finite cap rather than poll forever.
    presence_pf = dispatch_dir / ".presence" / f"{agent_id}.json"
    gated = presence_pf.exists()
    max_lifetime = args.max_lifetime
    if max_lifetime <= 0 and not gated:
        try:
            max_lifetime = float(
                os.environ.get("MCP_DISPATCH_STANDALONE_FALLBACK", STANDALONE_FALLBACK_SECONDS)
            )
        except ValueError:
            max_lifetime = STANDALONE_FALLBACK_SECONDS
    deadline = None if max_lifetime <= 0 else time.monotonic() + max_lifetime

    if args.follow:
        return _follow(
            dispatch_dir,
            agent_id,
            notify_on,
            args.interval,
            gated,
            presence_pf,
            deadline,
            max_lifetime,
        )

    while True:
        hits = _qualifying(dispatch_dir, agent_id, notify_on)
        if hits:
            print(_summary(agent_id, notify_on, hits))
            return 0
        if gated and not _presence_is_live(presence_pf):
            print(
                f"[mcp-dispatch] session for {agent_id} ended (presence dropped) — waiter exiting."
            )
            return 0
        if deadline is not None and time.monotonic() >= deadline:
            print(
                f"[mcp-dispatch] no qualifying messages for {agent_id} within "
                f"{int(max_lifetime)}s (notify_on={notify_on}). Re-arm if still idle."
            )
            return 0
        time.sleep(args.interval)


if __name__ == "__main__":
    sys.exit(main())
