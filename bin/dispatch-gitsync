#!/usr/bin/env python3
"""Mirror this host's local dispatch bus to/from a shared git repo.

mcp-dispatch is a local-only file bus. This daemon bridges it to other machines:
it proxies the local DISPATCH_DIR <-> a git clone (git_transport's per-author
lanes), so agents reach agents on OTHER hosts with *zero* change to how they call
dispatch(). All git knowledge lives here, not in the server.

    dispatch-gitsync                     # run the daemon (one per host)
    dispatch-gitsync --once              # a single sync pass and exit (smoke / cron)
    dispatch-gitsync --mirror all        # full audited replica (vs default remote-only)
    dispatch-gitsync --no-presence-gate  # run forever, independent of any harness

    dispatch-gitsync init <url|slug|path>  # create/clone + seed + write [git] config
    dispatch-gitsync init --create owner/agent-bus   # gh-create a PRIVATE repo first
    dispatch-gitsync init <repo> --service # ...and run it as a service: whole setup
    dispatch-gitsync service install       # run it as a systemd user service
    dispatch-gitsync status                # is it running? repo, lanes, who's reachable

The daemon holds a host-level lock (one daemon per DISPATCH_DIR). By default it is
also presence-gated: it exits once no agent is live on the host, so a hook-spawned
daemon can't orphan. That gate assumes something claims presence — which only the
mcp-dispatch MCP *server* does. Agents on another harness (openclaw, Hermes, a
plain script) never do, so for them the daemon self-terminated after a minute and
messages stopped moving until someone ran git by hand. `--no-presence-gate` (or
`presence_gate = false`) drops the gate for that case: the daemon then runs until
stopped, which is what `service install` wires up.

A message arriving over git is materialized as a normal inbox .json, so it wakes a
parked session through the same path a local message does. Setup is one `init` per
host; then either `service install` (any harness) or wire
hooks/dispatch-gitsync-arm.py into SessionStart (Claude Code).
"""

from __future__ import annotations

import argparse
import os
import subprocess  # nosec B404 - argv-only calls to `git`/`systemctl`, never a shell
import sys
import time
from pathlib import Path

# git_bridge.py, dispatch_fs.py and dispatch_common.py live at the repo root.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
import dispatch_common as common  # noqa: E402
import dispatch_fs  # noqa: E402
import gitsync_service  # noqa: E402
from git_bridge import GitBridge  # noqa: E402


def _float_env(name: str, default: float) -> float:
    """Parse a float from the environment, falling back on anything unparseable.
    Raising here would happen at *import*, so a typo in a test-only knob would
    traceback every subcommand — `status` and `init` don't even use this."""
    try:
        return float(os.environ.get(name) or default)
    except ValueError:
        return default


# Exit if no agent ever appears (standalone safety). Env-overridable so the tests
# don't have to sit through a real minute — same idiom as dispatch-wait's
# MCP_DISPATCH_STANDALONE_FALLBACK.
STARTUP_GRACE_SECONDS = _float_env("MCP_DISPATCH_GITSYNC_GRACE", 60.0)

# Ungated (service) mode only: how long a failing sync backs off to, so a broken
# remote — expired token, dead network — is retried patiently instead of being
# hammered every `interval` seconds for as long as the machine is up.
MAX_BACKOFF_SECONDS = 60.0
# ...and the exponent is capped, because `failures` counts consecutive bad ticks
# forever: `interval * 2**failures` overflows float once failures passes ~1024
# (about 17h of a broken remote at the cap above), taking the daemon down with an
# OverflowError. 2**8 already exceeds any sane cap, so clamping costs nothing.
MAX_BACKOFF_SHIFT = 8


# ---------------------------------------------------------------------------
# Config / path resolution — the shared plumbing (config load, flat lookup,
# dispatch/state dir, md5 key, flock probe/acquire) lives in dispatch_common;
# only the git-specific bits stay here.
# ---------------------------------------------------------------------------


def _git_section(data: dict) -> dict:
    git = data.get("git")
    return git if isinstance(git, dict) else {}


def _float_cfg(git: dict, key: str, default: float) -> float:
    """A timing value from ``[git]``, tolerating a value that isn't a number.

    Raising here is disproportionate now that the daemon runs under a supervisor:
    ``interval = "fast"`` would exit(1) before the loop starts, systemd would
    respawn it every 5s until the start limit latched the unit `failed` for good,
    and the user's only clue would be a Python traceback in the journal. Warn and
    carry on with the default instead — a slightly-wrong cadence beats a dead
    bridge, which is the exact failure mode this whole change exists to remove.
    """
    raw = git.get(key)
    if raw is None:
        return default
    try:
        return float(raw)
    except (TypeError, ValueError):
        print(
            f"[gitsync] [git].{key} = {raw!r} is not a number — using {default}.",
            file=sys.stderr,
        )
        return default


def _config_path() -> Path:
    return Path(
        os.environ.get("MCP_DISPATCH_CONFIG")
        or os.path.expanduser("~/.config/mcp-dispatch/config.toml")
    )


def _host_lock_path(dispatch_dir: Path) -> Path:
    """One daemon per DISPATCH_DIR — the lock key is the dir, not an agent id."""
    return common.state_dir() / f"gitsync-{common.md5_key(str(dispatch_dir))}.lock"


def _backoff_delay(failures: int, interval: float) -> float:
    """Seconds to sleep after `failures` consecutive failed sync passes.

    Exponential from `interval` up to MAX_BACKOFF_SECONDS, with the exponent
    clamped: `failures` counts bad ticks for the process's whole life, and an
    unclamped `2**failures` overflows float past ~1024 — roughly 17h against a
    remote whose token expired — killing the daemon with an OverflowError.
    """
    if failures <= 0:
        return interval
    return min(interval * (2 ** min(failures, MAX_BACKOFF_SHIFT)), MAX_BACKOFF_SECONDS)


def _presence_gate(cli: bool | None, git: dict) -> bool:
    """Should the daemon exit when no agent holds a presence lock? CLI beats env
    beats config, defaulting to True — the gate is what keeps a *hook-spawned*
    daemon from orphaning, so only an explicit opt-out drops it."""
    if cli is not None:
        return cli
    env = os.environ.get("MCP_DISPATCH_GIT_PRESENCE_GATE")
    if env is not None and env.strip():
        return common.truthy(env)
    val = git.get("presence_gate")
    return True if val is None else bool(val)


# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------


def _run(cmd: list[str]) -> int:
    # Argument vector, never a shell string, and every caller builds it from a
    # literal verb list — the operator-supplied repo/slug only ever lands in an
    # argv slot, so it can't become a second command.
    return subprocess.run(cmd).returncode  # nosec B603


def _looks_like_url(s: str) -> bool:
    return "://" in s or (":" in s and "@" in s) or s.endswith(".git")


def _has_commits(repo_dir: Path) -> bool:
    return (
        subprocess.run(  # nosec B603 B607 - fixed verbs; `git` resolved via PATH like every other git call here
            ["git", "-C", str(repo_dir), "rev-parse", "HEAD"],
            capture_output=True,
        ).returncode
        == 0
    )


def _seed(repo_dir: Path, remote: str) -> None:
    """Give an empty repo an initial commit on `main` so lanes have a branch."""
    readme = repo_dir / "README.md"
    if not readme.exists():
        readme.write_text(
            "# mcp-dispatch git bus\n\n"
            "Per-author append-only message lanes for cross-host agent dispatch.\n"
            "Created by `dispatch-gitsync init`.\n"
        )
    _run(["git", "-C", str(repo_dir), "checkout", "-q", "-B", "main"])
    _run(["git", "-C", str(repo_dir), "add", "README.md"])
    _run(
        [
            "git",
            "-C",
            str(repo_dir),
            "-c",
            "user.name=dispatch-gitsync",
            "-c",
            "user.email=gitsync@mcp-dispatch",
            "commit",
            "-q",
            "-m",
            "seed bus",
        ]
    )
    _run(["git", "-C", str(repo_dir), "push", "-q", remote, "HEAD:main"])


def _write_git_config(repo_dir: Path, remote: str) -> None:
    cfgp = _config_path()
    cfgp.parent.mkdir(parents=True, exist_ok=True)
    text = cfgp.read_text() if cfgp.exists() else ""
    if "[git]" in text:
        print(
            f"[gitsync] {cfgp} already has a [git] section — not clobbering it. "
            f'Ensure: repo_dir = "{repo_dir}", remote = "{remote}", enabled = true.'
        )
        return
    block = (
        "\n# Added by `dispatch-gitsync init` — cross-host comms over git.\n"
        "[git]\n"
        "enabled = true\n"
        f'repo_dir = "{repo_dir}"\n'
        f'remote = "{remote}"\n'
        '# mirror = "remote-only"  # default; "all" = full audited replica\n'
    )
    with cfgp.open("a") as f:
        f.write(block)
    print(f"[gitsync] wrote [git] block to {cfgp}")


def cmd_init(argv: list[str]) -> int:
    ap = argparse.ArgumentParser(
        prog="dispatch-gitsync init",
        description="Create/clone a git bus repo, seed it, and write the [git] config.",
    )
    ap.add_argument("target", nargs="?", help="git URL, owner/name slug, or existing clone path")
    ap.add_argument("--create", action="store_true", help="gh repo create the slug PRIVATE first")
    ap.add_argument("--repo-dir", default=None, help="clone dest (default ~/.config/.../bus)")
    ap.add_argument("--remote", default="origin", help="git remote name (default origin)")
    ap.add_argument(
        "--service",
        action="store_true",
        help="also install the systemd user service, so the bridge runs without a "
        "Claude Code hook. Makes this the ONE command a new host needs.",
    )
    ap.add_argument(
        "--env",
        action="append",
        default=[],
        metavar="KEY=VALUE",
        help="passed through to `service install` (e.g. SSH_AUTH_SOCK)",
    )
    ap.add_argument(
        "--dry-run", action="store_true", help="with --service: plan the unit only — the clone and the [git] config "
        "are still written for real",
    )
    args = ap.parse_args(argv)

    repo_dir = Path(os.path.expanduser(args.repo_dir or "~/.config/mcp-dispatch/bus"))

    if (repo_dir / ".git").exists():
        print(f"[gitsync] reusing existing clone at {repo_dir}")
    else:
        target = args.target
        if args.create:
            if not target:
                print("[gitsync] --create needs an owner/name slug, e.g. --create you/agent-bus")
                return 2
            print(f"[gitsync] creating PRIVATE repo {target} via gh…")
            if _run(["gh", "repo", "create", target, "--private"]) != 0:
                print("[gitsync] gh repo create nonzero (may already exist) — trying clone.")
        if not target:
            print("[gitsync] need a target: a git URL, owner/name slug, or an existing clone path.")
            return 2
        local = Path(os.path.expanduser(target))
        if (local / ".git").exists():
            repo_dir = local
            print(f"[gitsync] using existing clone {repo_dir}")
        else:
            repo_dir.parent.mkdir(parents=True, exist_ok=True)
            clone = (
                ["git", "clone", target, str(repo_dir)]
                if _looks_like_url(target) or local.exists()
                else ["gh", "repo", "clone", target, str(repo_dir)]
            )
            if _run(clone) != 0:
                print("[gitsync] clone failed.")
                return 2

    if not _has_commits(repo_dir):
        print("[gitsync] seeding empty repo with an initial commit…")
        _seed(repo_dir, args.remote)

    _write_git_config(repo_dir, args.remote)
    print(f"[gitsync] ready. repo_dir={repo_dir} remote={args.remote}")
    if args.service:
        # Same process, so `service` reads the config `_write_git_config` just
        # wrote. Both halves are idempotent (an existing clone is reused, an
        # existing [git] block is left alone, the unit is regenerated), which makes
        # the whole command safe to re-run — it is also how you upgrade.
        print("[gitsync] installing the systemd user service…")
        forwarded = ["install", *(f"--env={e}" for e in args.env)]
        if args.dry_run:
            forwarded.append("--dry-run")
        return cmd_service(forwarded)
    print("[gitsync] run it with:  dispatch-gitsync   (or enable hooks/dispatch-gitsync-arm.py).")
    print("[gitsync] not on Claude Code? re-run this with --service to run it as a daemon.")
    return 0


def cmd_service(argv: list[str]) -> int:
    """Install/remove the systemd user unit — the harness-independent way to run.

    The SessionStart hook only exists inside Claude Code; anything else talking
    through the relay (openclaw, Hermes, the TUI, a cron job) never starts a daemon
    and silently stops exchanging messages. This puts the daemon under the user's
    own init instead, so it runs regardless of which agent runtime is alive.
    """
    ap = argparse.ArgumentParser(
        prog="dispatch-gitsync service",
        description="Run the bridge as a systemd user service (any harness, no hooks).",
    )
    ap.add_argument(
        "action", nargs="?", default="install", choices=["install", "uninstall", "show"]
    )
    ap.add_argument("--dry-run", action="store_true", help="print the plan/unit, write nothing")
    ap.add_argument("--no-enable", action="store_true", help="write the unit but don't start it")
    ap.add_argument(
        "--env",
        action="append",
        default=[],
        metavar="KEY=VALUE",
        help="extra Environment= line (repeatable). A user service inherits almost "
        "nothing from your shell, so this is where SSH_AUTH_SOCK etc. go.",
    )
    args = ap.parse_args(argv)

    try:
        if args.action == "uninstall":
            for step in gitsync_service.uninstall(dry_run=args.dry_run):
                print(f"  {'would ' if args.dry_run else ''}{step}")
            return 0

        data = common.load_config()
        git = _git_section(data)
        repo_dir = os.environ.get("MCP_DISPATCH_GIT_REPO") or git.get("repo_dir")
        if not repo_dir:
            print("[gitsync] no git clone configured — run `dispatch-gitsync init <repo>` first.")
            return 2
        if not (git.get("enabled") or os.environ.get("MCP_DISPATCH_GIT_ENABLED")):
            # A service around a disabled bridge would exit immediately and be
            # restarted forever. Fail loudly here instead of shipping a flapping unit.
            print("[gitsync] [git].enabled is false — enable it before installing the service.")
            return 2

        interval = git.get("interval")
        unit = gitsync_service.render_unit(
            python=sys.executable,
            daemon=Path(__file__).resolve(),
            repo_root=Path(__file__).resolve().parent.parent,
            config_path=_config_path().expanduser().resolve(),
            dispatch_dir=common.dispatch_dir(data),
            repo_dir=Path(os.path.expanduser(str(repo_dir))),
            state_dir=common.state_dir(),
            group_mode=bool(common.flat(data, "group_mode")),
            interval=float(interval) if interval is not None else None,
            env=gitsync_service.validate_env(args.env),
        )
        if args.action == "show":
            print(unit, end="")
            return 0

        steps = gitsync_service.install(unit, enable=not args.no_enable, dry_run=args.dry_run)
    except gitsync_service.ServiceError as e:
        print(f"[gitsync] {e}")
        return 2
    except subprocess.CalledProcessError as e:
        print(f"[gitsync] systemctl failed: {(e.stderr or '').strip() or e}")
        return 2

    for step in steps:
        print(f"  {'would ' if args.dry_run else ''}{step}")
    if args.dry_run:
        print("\n(--dry-run: nothing written. `service show` prints the unit itself.)")
    else:
        print(
            "\n[gitsync] the bridge now runs independently of any agent harness.\n"
            "  logs:   journalctl --user -u mcp-dispatch-gitsync -f\n"
            "  upgrade: re-run `dispatch-gitsync service install` after changing config"
        )
    return 0


def cmd_status(argv: list[str]) -> int:
    argparse.ArgumentParser(prog="dispatch-gitsync status").parse_args(argv)
    data = common.load_config()
    git = _git_section(data)
    dispatch_dir = common.dispatch_dir(data)
    repo_dir = git.get("repo_dir") or os.environ.get("MCP_DISPATCH_GIT_REPO")
    repo_dir = Path(os.path.expanduser(str(repo_dir))) if repo_dir else None

    print(f"enabled:          {bool(git.get('enabled'))}")
    print(f"daemon running:   {common.flock_held(_host_lock_path(dispatch_dir))}")
    print(f"dispatch_dir:     {dispatch_dir}")
    print(f"repo_dir:         {repo_dir or '(unset)'}")
    print(f"remote:           {git.get('remote') or '(local-only)'}")
    print(f"mirror:           {git.get('mirror') or 'remote-only'}")
    for line in gitsync_service.status_lines():
        print(line)
    if repo_dir and (repo_dir / "lanes").is_dir():
        print(f"DM lanes:         {len(list((repo_dir / 'lanes').glob('*.jsonl')))}")
    if dispatch_dir.is_dir():
        print(f"live local:       {dispatch_fs.live_agents(dispatch_dir) or '(none)'}")
        rem = dispatch_dir / ".remote"
        if rem.is_dir():
            print(f"remote-known:     {[p.stem for p in sorted(rem.glob('*.json'))] or '(none)'}")
    return 0


def cmd_run(argv: list[str]) -> int:
    ap = argparse.ArgumentParser(
        prog="dispatch-gitsync", description="Mirror the local dispatch bus to/from git."
    )
    ap.add_argument("--interval", type=float, default=None, help="seconds between sync passes")
    ap.add_argument("--once", action="store_true", help="run a single pass and exit")
    ap.add_argument(
        "--mirror", choices=["remote-only", "all"], default=None, help="override mirror mode"
    )
    ap.add_argument("--repo-dir", default=None, help="override the git clone path")
    gate = ap.add_mutually_exclusive_group()
    gate.add_argument(
        "--no-presence-gate",
        dest="presence_gate",
        action="store_false",
        default=None,
        help="run until stopped instead of exiting when no agent is live (for a service)",
    )
    gate.add_argument(
        "--presence-gate",
        dest="presence_gate",
        action="store_true",
        default=None,
        help="force the default gated lifetime even if config disables it",
    )
    args = ap.parse_args(argv)

    data = common.load_config()
    git = _git_section(data)

    enabled = bool(git.get("enabled")) or bool(os.environ.get("MCP_DISPATCH_GIT_ENABLED"))
    if not enabled and not (args.once or args.repo_dir):
        print(
            "[gitsync] [git].enabled is false — not bridging. Run `dispatch-gitsync "
            "init <repo>` to set it up, or pass --repo-dir to bridge ad hoc."
        )
        return 0

    repo_dir = args.repo_dir or os.environ.get("MCP_DISPATCH_GIT_REPO") or git.get("repo_dir")
    if not repo_dir:
        print("[gitsync] no git clone configured — run `dispatch-gitsync init <repo>` first.")
        return 2
    repo_dir = Path(os.path.expanduser(str(repo_dir)))
    if not (repo_dir / ".git").exists():
        print(
            f"[gitsync] {repo_dir} is not a git clone (no .git). "
            "Run `dispatch-gitsync init <repo>` first."
        )
        return 2

    dispatch_dir = common.dispatch_dir(data)
    remote = os.environ.get("MCP_DISPATCH_GIT_REMOTE") or git.get("remote")
    mirror = args.mirror or git.get("mirror") or "remote-only"
    interval = args.interval if args.interval is not None else _float_cfg(git, "interval", 2.0)
    group_mode = bool(common.flat(data, "group_mode"))
    gated = _presence_gate(args.presence_gate, git)

    if not dispatch_dir.is_dir():
        # Gated (hook-spawned) runs are transient, so a missing relay just means
        # "nothing to do yet". A service, though, legitimately starts at login
        # *before* the first agent has ever created the relay — exiting there would
        # need a manual restart to ever recover, so it waits instead.
        if gated or args.once:
            print(f"[gitsync] no relay at {dispatch_dir} — nothing to mirror.")
            return 0
        print(f"[gitsync] waiting for a relay to appear at {dispatch_dir}…")
        try:
            while not dispatch_dir.is_dir():
                time.sleep(max(interval, 1.0))
        except KeyboardInterrupt:
            return 0
        print(f"[gitsync] relay appeared at {dispatch_dir}.")

    # Inbound fetch pacing. `git fetch` costs ~170ms of CPU against a real remote
    # while the whole local scan costs ~12ms, so polling it every `interval` for as
    # long as the machine is up is where all of a 24/7 daemon's CPU goes. Let the
    # fetch cadence decay toward `max_fetch_interval` while the bus is silent; any
    # traffic in either direction snaps it straight back to `interval`. A --once
    # pass and any explicit 0 keep the fetch-every-tick behaviour.
    max_fetch = _float_cfg(git, "max_fetch_interval", 30.0)
    bridge = GitBridge(
        dispatch_dir,
        repo_dir,
        remote=remote,
        mirror=mirror,
        group_mode=group_mode,
        poll_interval=interval,
        max_fetch_interval=0.0 if args.once else max_fetch,
    )

    # Startup catch-up: if a prior run committed lane records but couldn't push
    # (a network/auth outage froze the remote), flush them now so a restart alone
    # recovers — no need to wait for new traffic to trigger the next push.
    bridge.flush_pending()

    if args.once:
        bridge.tick_guarded()
        return 0

    # One daemon per host. A gated run (a racing SessionStart hook) finds the lock
    # held and exits quietly. An ungated run WAITS for it instead: a service and a
    # hook-spawned daemon coexist on one host, and whichever loses the race must
    # take over when the other dies rather than exiting into a systemd restart loop.
    lock_path = _host_lock_path(dispatch_dir)
    lock = common.acquire_flock(lock_path, attempts=2)
    if lock is None:
        if gated:
            print(f"[gitsync] a daemon is already mirroring {dispatch_dir}; not starting a second.")
            return 0
        print(f"[gitsync] another daemon holds {dispatch_dir}; waiting to take over…")
        try:
            while lock is None:
                time.sleep(max(interval, 1.0))
                lock = common.acquire_flock(lock_path)
        except KeyboardInterrupt:
            return 0
        print("[gitsync] took over the host lock.")

    print(
        f"[gitsync] mirroring {dispatch_dir} <-> {repo_dir} "
        f"(remote={remote or 'local'}, mirror={mirror}, send every {interval}s, "
        f"fetch {interval}s–{max_fetch or interval}s, "
        f"lifetime={'presence-gated' if gated else 'until stopped'})"
    )

    # Presence-gated lifetime: exit once the host goes quiet (no live agents), so a
    # backgrounded daemon can't outlive every session and orphan. A startup grace
    # tolerates being launched a beat before the first session's presence appears.
    # Ungated, none of that applies — the supervisor owns the lifetime.
    seen_live = False
    start = time.monotonic()
    failures = 0
    try:
        while True:
            ok = bridge.tick_guarded()
            if gated:
                live = bool(dispatch_fs.live_agents(dispatch_dir))
                if live:
                    seen_live = True
                elif seen_live:
                    print("[gitsync] no live agents on host — exiting (a new session re-arms me).")
                    return 0
                elif time.monotonic() - start > STARTUP_GRACE_SECONDS:
                    print("[gitsync] no agents appeared within startup grace — exiting.")
                    return 0
                time.sleep(interval)
                continue
            # Ungated: back off on a run of failures so a broken remote (expired
            # token, no network) isn't retried every 2s for the machine's uptime,
            # then snap back to `interval` the moment a pass succeeds.
            failures = 0 if ok else failures + 1
            time.sleep(_backoff_delay(failures, interval))
    except KeyboardInterrupt:
        return 0


def main() -> int:
    argv = sys.argv[1:]
    if argv and argv[0] == "init":
        return cmd_init(argv[1:])
    if argv and argv[0] == "status":
        return cmd_status(argv[1:])
    if argv and argv[0] == "service":
        return cmd_service(argv[1:])
    return cmd_run(argv)


if __name__ == "__main__":
    sys.exit(main())
